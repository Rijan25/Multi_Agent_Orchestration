# Copy this file to .env and fill in your key to use the real Anthropic API.
# Without this, the pipeline runs on the built-in deterministic mock (offline-safe).
#
#   cp .env.example .env
#
# The server reads ANTHROPIC_API_KEY from the environment at startup.
# Set it in your shell instead if you prefer:
#   export ANTHROPIC_API_KEY=sk-ant-...   (Mac/Linux)
#   $env:ANTHROPIC_API_KEY="sk-ant-..."   (Windows PowerShell)

ANTHROPIC_API_KEY=sk-ant-your-key-here
